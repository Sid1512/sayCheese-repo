# DayAdapt API - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Server
# ===========================================
NODE_ENV=development
PORT=3000
API_BASE_URL=/api/v1

# ===========================================
# Firebase (Backend & Database)
# ===========================================
# Firestore: user profiles, wardrobe items, wear logs
# Storage: clothing photos
FIREBASE_PROJECT_ID=your-project-id
# Path to service account JSON (for Admin SDK in Node.js), or set GOOGLE_APPLICATION_CREDENTIALS
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ===========================================
# Auth (if using custom JWT instead of Firebase Auth)
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# Anthropic (Claude) - Vision & Reasoning LLM
# ===========================================
ANTHROPIC_API_KEY=sk-ant-api03-...
# Used for: wardrobe item tagging (vision), outfit scan recognition, recommendations

# ===========================================
# Weather & Environment (Open-Meteo — free, no key)
# ===========================================
# Main weather: temp, feels-like, visibility, UV, wind, rain, humidity
OPEN_METEO_WEATHER_URL=https://api.open-meteo.com/v1/forecast
# Air quality: AQI, optional pollen
OPEN_METEO_AIR_QUALITY_URL=https://air-quality.api.open-meteo.com/v1/air-quality
